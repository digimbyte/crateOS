#cloud-config
# CrateOS autoinstall seed — targets Ubuntu 24.04 LTS (Noble Numbat)
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us

  identity:
    hostname: crateos
    username: crate
    # Default password: "crateos" (change on first login)
    # Generated with: openssl passwd -6 crateos
    password: "$6$rounds=4096$placeholder$placeholder"

  ssh:
    install-server: true
    allow-pw: true

  # Keep this list in sync with packaging/config/packages.yaml (required)
  packages:
    - openssh-server
    - network-manager
    - nftables
    - openssl
    - ca-certificates
    - curl
    - wget
    - jq
    - yq
    - git
    - rsync
    - dos2unix
    - lsof
    - chrony
    - unattended-upgrades
    - needrestart
    - logrotate
    - btop
    - ncdu
    - smartmontools
    - nvme-cli
    - lm-sensors
    - fancontrol
    - hddtemp
    - iperf3
    - ethtool
    - iw
    - dnsutils
    - mtr-tiny
    - pciutils
    - usbutils
    - fail2ban
    - tmux
    - build-essential
    - pkg-config
    - python3
    - python3-venv
    - python3-pip
    - powershell

  late-commands:
    # Install CrateOS packages.
    # In online mode, these would be fetched from a release URL.
    # In offline-lite mode, they're embedded on the ISO.
    - |
      if [ -d /cdrom/crateos-debs ]; then
        cp /cdrom/crateos-debs/*.deb /target/tmp/
        curtin in-target -- dpkg -i /tmp/crateos*.deb
        rm -f /target/tmp/crateos*.deb
      else
        echo "CrateOS debs not found on media — skipping offline install"
      fi
