# CrateOS Raspberry Pi 4/5 Platform Defaults
# Inherits from seed-defaults.env and adds/overrides RPi-specific settings

# Base system config (same as x86)
HOSTNAME=crateos-rpi
DEFAULT_USER=crate
DEFAULT_PASSWORD=crateos
PASSWORD_HASH='$6$rounds=4096$crateos$JQnuc6Iv9bv9TxSsnG8Tz0BPVK/TGO3qFZ1KdK6d1HeGYzNEgnKKNv2ZyrJ0CYa9aDYUfVrH7Jd2WAwzFq3om1'

# RPi-specific settings
RPI_BOARD_TYPE="rpi4_5"              # Raspberry Pi 4/5 (arm64)
RPI_OS_VARIANT="bookworm"             # Debian Bookworm (RPi OS base)
RPI_MEMORY_MB="4096"                 # Assume 4GB for RPi 4/5
RPI_GPU_MEMORY_MB="128"              # GPU memory split

# Networking
ENABLE_SSH="yes"
SSH_PASSWORD_AUTH="yes"

# GPIO and hardware interfaces
ENABLE_I2C="yes"
ENABLE_SPI="yes"
ENABLE_1WIRE="no"
ENABLE_UART="no"

# Performance tuning for ARM
ARM_FREQ="1800"                      # CPU frequency (MHz)
GPU_FREQ="600"                       # GPU frequency (MHz)
OVER_VOLTAGE="0"                     # No overclocking

# Optional: GPU memory can be increased for media workloads
# GPU_MEM="256"                       # Increase if running GPU workloads
