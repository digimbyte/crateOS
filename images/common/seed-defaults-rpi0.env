# CrateOS Raspberry Pi Zero 2 W Minimal Defaults
# Optimized for 512MB RAM and 4GB+ microSD card

# Base system config
HOSTNAME=crateos-zero
DEFAULT_USER=crate
DEFAULT_PASSWORD=crateos
PASSWORD_HASH='$6$rounds=4096$crateos$JQnuc6Iv9bv9TxSsnG8Tz0BPVK/TGO3qFZ1KdK6d1HeGYzNEgnKKNv2ZyrJ0CYa9aDYUfVrH7Jd2WAwzFq3om1'

# RPi Zero 2 specific settings
RPI_BOARD_TYPE="rpi0_2"              # Raspberry Pi Zero 2 W (arm64)
RPI_OS_VARIANT="bookworm-lite"       # Lite variant (no GUI)
RPI_MEMORY_MB="512"                  # Fixed 512MB RAM
RPI_GPU_MEMORY_MB="64"               # Minimal GPU memory for Zero

# Networking (minimal)
ENABLE_SSH="yes"
SSH_PASSWORD_AUTH="yes"

# GPIO and hardware interfaces (Zero has limited I/O)
ENABLE_I2C="yes"
ENABLE_SPI="yes"
ENABLE_1WIRE="no"
ENABLE_UART="no"

# Minimal performance (conservative for stability)
ARM_FREQ="1000"                      # Reduced CPU frequency to conserve power
GPU_FREQ="300"                       # Very low GPU frequency
OVER_VOLTAGE="0"                     # No overclocking (thermal issues)

# Memory constraints
SWAP_SIZE_MB="512"                   # Enable swap to help with RAM pressure
ZRAM_ENABLED="yes"                   # Enable zram compression

# Service minimization for Zero
DISABLE_SERVICES=(
    "dhcpcd"                         # Use systemd-networkd instead
    "avahi-daemon"                   # mDNS not needed
)

# Package optimization
MINIMAL_INSTALL="yes"                # Skip unnecessary packages
NO_GUI="yes"                         # No desktop environment
NO_BLUETOOTH="yes"                   # Disable Bluetooth to save RAM
NO_WIFI="no"                         # Keep WiFi (important for Zero 2 W)
