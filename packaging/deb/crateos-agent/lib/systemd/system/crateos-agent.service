[Unit]
Description=CrateOS Agent — platform state enforcer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/crateos-agent
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=crateos-agent

[Install]
WantedBy=multi-user.target
