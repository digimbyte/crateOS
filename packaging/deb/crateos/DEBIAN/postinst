#!/bin/bash
set -e

disable_stock_motd_script() {
    local script="$1"
    if [ -f "$script" ]; then
        chmod 0644 "$script" 2>/dev/null || true
    fi
}

chmod 755 /etc/update-motd.d/00-crateos-header 2>/dev/null || true
chmod 755 /etc/update-motd.d/10-help-text 2>/dev/null || true
mkdir -p /etc/ssh/sshd_config.d
cat > /etc/ssh/sshd_config.d/10-crateos.conf <<'EOF'
# CrateOS: force SSH sessions into the CrateOS console.
# Users land in the TUI instead of a raw shell.
# Admin break-glass access is handled via the console's escape hatch.
ForceCommand /usr/local/bin/crateos console
EOF
chmod 0644 /etc/ssh/sshd_config.d/10-crateos.conf 2>/dev/null || true
chmod 0755 /usr/local/bin/crateos-login-shell 2>/dev/null || true
chmod 0755 /usr/local/bin/crateos-shell-wrapper 2>/dev/null || true
chmod 0644 /etc/profile.d/10-crateos-tty1.sh 2>/dev/null || true
disable_stock_motd_script /etc/update-motd.d/50-landscape-sysinfo
disable_stock_motd_script /etc/update-motd.d/50-motd-news
disable_stock_motd_script /etc/update-motd.d/80-livepatch
disable_stock_motd_script /etc/update-motd.d/88-esm-announce
disable_stock_motd_script /etc/update-motd.d/91-contract-ua-esm-status
disable_stock_motd_script /etc/update-motd.d/91-release-upgrade
disable_stock_motd_script /etc/update-motd.d/92-unattended-upgrades
disable_stock_motd_script /etc/update-motd.d/95-hwe-eol
disable_stock_motd_script /etc/update-motd.d/97-overlayroot
disable_stock_motd_script /etc/update-motd.d/98-fsck-at-reboot
disable_stock_motd_script /etc/update-motd.d/98-reboot-required
mkdir -p /etc/default
cat > /etc/default/motd-news <<'EOF'
ENABLED=0
EOF


echo "crateos: installed successfully"
